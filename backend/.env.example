# ========================================
# 智能二手商品发布助手 - 环境变量（模板）
# 复制为 .env 并填入你的真实值
# ========================================

# ============================================================
# 运行环境
# ============================================================
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# 服务器配置
# ============================================================
BASE_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
STATIC_PREFIX=/static

# ============================================================
# 阿里云百炼（Qwen-VL-Max 视觉识别）
# 注册: https://dashscope.aliyun.com
# ============================================================
DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_VL_MODEL=qwen-vl-max

# ============================================================
# DeepSeek 官方 API（文本生成 + 智能定价）
# 注册: https://platform.deepseek.com
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# MySQL 数据库
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=market_transactions

# ============================================================
# ML 模型路径（YOLO/CLIP）
# ============================================================
YOLO_MODEL_PATH=app/ml/models/best.pt
DEFECT_MODEL_PATH=app/ml/models/defect_best.pt
YOLO_PRETRAINED_PATH=yolov8n.pt

# ============================================================
# Qdrant 向量数据库（以图搜图）
# ============================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=market_items
QDRANT_VECTOR_SIZE=512

# ============================================================
# CLIP 模型配置
# ============================================================
CLIP_MODEL_NAME=ViT-B/32

# ============================================================
# 图片上传配置
# ============================================================
UPLOAD_DIR=static/uploads
MAX_IMAGE_COUNT=3
MAX_UPLOAD_SIZE=10485760

# ============================================================
# 后台任务
# ============================================================
BACKGROUND_TASK_RETRIES=3
BACKGROUND_TASK_RETRY_DELAY=1.0
BACKGROUND_TASK_ENABLED=true
ERROR_DATA_DIR=data/error_data

# ============================================================
# JWT 认证
# ============================================================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS 跨域
# ============================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ============================================================
# OneBound 淘宝价格 API（免费注册: https://open.onebound.cn）
# ============================================================
ONEBOUND_API_KEY=your_onebound_key_here
ONEBOUND_API_SECRET=your_onebound_secret_here
