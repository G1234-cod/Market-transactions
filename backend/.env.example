# ========================================
# 智能二手商品发布助手 - 环境变量模板
# 复制此文件为 .env 并填入真实值
# ========================================

# ============================================================
# 运行环境
# ============================================================
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# 服务器配置
# ============================================================
BASE_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
STATIC_PREFIX=/static

# ============================================================
# 阿里云百炼（Qwen-VL-Max 视觉识别）
# ============================================================
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_VL_MODEL=qwen-vl-max

# ============================================================
# DeepSeek 官方 API（文本生成 + 智能定价）
# ============================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# MySQL 数据库
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=market_transactions

# ============================================================
# ML 模型路径
# ============================================================
YOLO_MODEL_PATH=app/ml/models/best.pt
DEFECT_MODEL_PATH=app/ml/models/defect_best.pt
YOLO_PRETRAINED_PATH=yolov8n.pt

# ============================================================
# Qdrant 向量数据库（以图搜图）
# ============================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=market_items
QDRANT_VECTOR_SIZE=512

# ============================================================
# CLIP 模型配置
# ============================================================
# open_clip 格式使用连字符，非 HuggingFace 斜杠格式
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# ============================================================
# 图片上传配置
# ============================================================
UPLOAD_DIR=static/uploads
MAX_IMAGE_COUNT=3
MAX_UPLOAD_SIZE=10485760

# ============================================================
# 后台任务配置
# ============================================================
BACKGROUND_TASK_RETRIES=3
BACKGROUND_TASK_RETRY_DELAY=1.0
BACKGROUND_TASK_ENABLED=true
ERROR_DATA_DIR=data/error_data

# ============================================================
# JWT 认证配置
# ============================================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS 跨域配置
# ============================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
